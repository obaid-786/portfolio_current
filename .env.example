# ===== General =====
APP_NAME="Obaidullah Siddiqui — Portfolio"
ENVIRONMENT=development
DEBUG=true
SITE_URL=http://localhost:8000

# ===== SMTP / Email (contact form) =====
# For Gmail: enable 2FA, then create an "App Password" and use it below.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_16_char_app_password
SMTP_FROM=your_email@gmail.com
CONTACT_RECIPIENT=obaidsid0@gmail.com

# Set to false locally if you don't want to actually send emails.
EMAIL_ENABLED=false
